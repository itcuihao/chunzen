{
  "name": "chunzen",
  "displayName": "春蝉 — 学术论文沉浸式阅读",
  "description": "春蝉 — 在 VSCode 中沉浸式阅读学术 PDF，支持实时翻译、期刊信息查询（IF、中科院分区）",
  "version": "0.1.0",
  "publisher": "chunzen",
  "repository": {
    "type": "git",
    "url": "https://gitea.awsl.icu/itcuihao/chunzen.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "pdf",
    "academic",
    "translation",
    "research",
    "论文"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "icon": "media/icon.png",
  "contributes": {
    "customEditors": [
      {
        "viewType": "chunzen.pdfViewer",
        "displayName": "春蝉 PDF 阅读器",
        "selector": [
          {
            "filenamePattern": "*.pdf"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "chunzen.openSidePanel",
        "title": "春蝉：打开翻译面板",
        "icon": "$(book)"
      },
      {
        "command": "chunzen.clearCache",
        "title": "春蝉：清除翻译缓存"
      },
      {
        "command": "chunzen.configureEngines",
        "title": "春蝉：配置翻译引擎"
      },
      {
        "command": "chunzen.openPdf",
        "title": "春蝉：用春蝉 PDF 阅读器打开"
      },
      {
        "command": "chunzen.captureFigureScreenshot",
        "title": "春蝉：截图当前页图像区域",
        "icon": "$(device-camera)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "chunzen.openSidePanel",
          "when": "activeCustomEditorId == 'chunzen.pdfViewer'",
          "group": "navigation"
        },
        {
          "command": "chunzen.captureFigureScreenshot",
          "when": "activeCustomEditorId == 'chunzen.pdfViewer'",
          "group": "navigation@2"
        }
      ],
      "explorer/context": [
        {
          "command": "chunzen.openPdf",
          "when": "resourceExtname == .pdf",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "春蝉 PDF 阅读器",
      "properties": {
        "chunzen.translation.priority": {
          "type": "array",
          "default": [
            "baidu",
            "deepl",
            "openai",
            "custom",
            "claudeCli"
          ],
          "description": "翻译引擎优先级顺序（从高到低）"
        },
        "chunzen.translation.baidu.appId": {
          "type": "string",
          "default": "",
          "description": "百度翻译 App ID"
        },
        "chunzen.translation.baidu.secretKey": {
          "type": "string",
          "default": "",
          "description": "百度翻译密钥"
        },
        "chunzen.translation.deepl.apiKey": {
          "type": "string",
          "default": "",
          "description": "DeepL API Key"
        },
        "chunzen.translation.deepl.freeApi": {
          "type": "boolean",
          "default": true,
          "description": "使用 DeepL 免费版 API（api-free.deepl.com）"
        },
        "chunzen.translation.openai.apiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI / MiniMax / 兼容接口 API Key"
        },
        "chunzen.translation.openai.baseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "OpenAI 兼容接口 Base URL（可填 MiniMax、Gemini 等代理地址）"
        },
        "chunzen.translation.openai.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "使用的模型名称（如 gpt-4o-mini、MiniMax-M2.7 等）"
        },
        "chunzen.translation.openai.systemPrompt": {
          "type": "string",
          "default": "你是一个学术论文翻译专家。请将以下英文学术句子翻译成中文，保持专业术语准确，语言简洁流畅。只输出翻译结果，不要解释。",
          "description": "AI 翻译的系统提示词（可自定义）"
        },
        "chunzen.translation.custom.url": {
          "type": "string",
          "default": "",
          "description": "自定义翻译 HTTP 接口 URL"
        },
        "chunzen.translation.custom.headers": {
          "type": "object",
          "default": {},
          "description": "自定义接口请求头"
        },
        "chunzen.translation.custom.bodyTemplate": {
          "type": "string",
          "default": "{\"text\": \"{{text}}\", \"target_lang\": \"ZH\"}",
          "description": "请求体模板，用 {{text}} 占位"
        },
        "chunzen.translation.custom.responsePath": {
          "type": "string",
          "default": "result",
          "description": "从响应 JSON 中提取翻译结果的路径（如 data.translation）"
        },
        "chunzen.translation.claudeCli.enabled": {
          "type": "boolean",
          "default": false,
          "description": "启用 claude -p 命令行翻译"
        },
        "chunzen.translation.claudeCli.prompt": {
          "type": "string",
          "default": "将以下学术英文翻译为中文，只输出译文：",
          "description": "Claude CLI 翻译提示词"
        },
        "chunzen.cache.maxSize": {
          "type": "number",
          "default": 500,
          "description": "翻译缓存最大条数"
        },
        "chunzen.journal.enabled": {
          "type": "boolean",
          "default": true,
          "description": "启用期刊信息查询"
        },
        "chunzen.journal.source": {
          "type": "string",
          "enum": [
            "ablesci",
            "letpub"
          ],
          "default": "ablesci",
          "description": "期刊信息查询数据源，支持科研通 (ablesci) 和 LetPub"
        },
        "chunzen.layout.useModel": {
          "type": "boolean",
          "default": false,
          "description": "是否启用外部版面分析模型（失败自动回退到规则引擎）"
        },
        "chunzen.layout.modelEndpoint": {
          "type": "string",
          "default": "",
          "description": "版面分析模型端点（POST），例如 http://127.0.0.1:8765/layout"
        },
        "chunzen.layout.timeoutMs": {
          "type": "number",
          "default": 3500,
          "description": "版面分析模型请求超时（毫秒）"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "vsix": "npm run package && node ./node_modules/@vscode/vsce/out/main.js package --allow-missing-repository --baseContentUrl \"https://gitea.awsl.icu/itcuihao/chunzen/src/branch/main\" --baseImagesUrl \"https://gitea.awsl.icu/itcuihao/chunzen/raw/branch/main\"",
    "deploy": "npm run vsix && code --uninstall-extension chunzen.chunzen; code --install-extension chunzen-0.1.0.vsix && echo '✅ 安装完成，请在VSCode执行 Reload Window'",
    "compile-tests": "tsc -p . --outDir out",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/vsce": "^3.9.1",
    "autoprefixer": "^10.4.19",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.11.0",
    "eslint": "^8.0.0",
    "lucide-react": "^0.379.0",
    "mini-css-extract-plugin": "^2.9.0",
    "pdfjs-dist": "^5.7.284",
    "postcss": "^8.4.38",
    "postcss-loader": "^8.1.1",
    "tailwind-merge": "^2.3.0",
    "tailwindcss": "^3.4.3",
    "ts-loader": "^9.0.0",
    "typescript": "^5.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "node-fetch": "^3.3.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.2"
  }
}
