{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2022",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "outDir": "out",
    "lib": ["ES2022", "DOM"],
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "noImplicitAny": true,
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules", ".vscode-test"]
}
